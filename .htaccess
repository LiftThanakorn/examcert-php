Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(\.git|\.agents|config|controllers|models|setup|docs|logs)(/|$) - [F,L]
    RewriteRule ^(WORKLOG|PROJECT|README|SETUP-LOCAL|master-prompt|frontend-guide|certificate-verify-mockup).*\.(md|html)$ - [F,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L,QSA]
</IfModule>
